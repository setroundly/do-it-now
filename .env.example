# App
NEXT_PUBLIC_APP_NAME=どぅいっとなう
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth（Google ログイン）
# Dashboard → Authentication → Providers → Google を有効化
# Redirect URLs に以下を追加:
#   http://localhost:3000/auth/callback
#   https://あなたのドメイン/auth/callback
# Google Cloud Console で OAuth クライアントを作成し、Client ID/Secret を Supabase に設定

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Legacy JWT keys:
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Or newer publishable/secret keys (either pair works):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# Admin（/admin ログイン・投稿削除）
ADMIN_SECRET=your-random-secret-at-least-16-chars

# Vercel Cron（15分ごとに締切超過タスクを失敗化）
# Vercel が自動設定。ローカル検証用に同じ値を入れておくとよい
CRON_SECRET=your-random-cron-secret

# Resend（締切リマインドメール）
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=onboarding@resend.dev
# ドメイン未認証の間は Resend 登録メール宛のみ送信可
# External links（任意・寄付フォールバックURL）
# NEXT_PUBLIC_SETROUNDLY_URL=https://setroundly.com
# NEXT_PUBLIC_DEFAULT_DONATE_URL=https://www.jrc.or.jp/contribute/
