# App
NEXT_PUBLIC_APP_NAME=どぅいっとなう
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Legacy JWT keys:
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Or newer publishable/secret keys (either pair works):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# Admin（/admin ログイン・投稿削除）
ADMIN_SECRET=your-random-secret-at-least-16-chars

# Resend（失敗時に見届け人へメール）
# 1) resend.com で API Key 作成 → RESEND_API_KEY
# 2) ドメイン未認証の間は EMAIL_FROM=onboarding@resend.dev のみ可、届け先は登録メールのみ
# 3) ドメイン認証後: EMAIL_FROM=DoItNow <noreply@あなたのドメイン>
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# External links（任意・寄付フォールバックURL）
# NEXT_PUBLIC_SETROUNDLY_URL=https://setroundly.com
# NEXT_PUBLIC_DEFAULT_DONATE_URL=https://www.jrc.or.jp/contribute/
